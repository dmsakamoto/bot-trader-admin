# Supabase — same instance as bot-trader-web
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. NEVER expose to client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated Supabase auth.users.id UUIDs allowed to use this app.
ADMIN_USER_IDS=

# Sentry error + performance monitoring. Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=

# Optional — enables source-map upload during build (set in Vercel).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

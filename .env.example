# Supabase — same instance as bot-trader-web
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. NEVER expose to client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Admin allow-list. Supply EITHER format (both supported, merged at runtime):
#   Local dev: one comma-separated list
ADMIN_USER_IDS=
#   Vercel: numbered vars (Vercel's "Value" field rejects comma-UUIDs in some
#   flows). Fill sequentially from _1; scan stops at the first gap.
# ADMIN_USER_ID_1=
# ADMIN_USER_ID_2=
